custom_minimum_size = Vector2(400, 0)
layout_mode = 2
size_flags_horizontal = 4
text = "Developer mode is required to create Symlinks without admin privileges.

They are required by the mod loader to create a temporary enviroment for the game to run in.
Symlinks are files that point to another path, acting as a regular file. This lets the mod loader \"copy\" the game files to the enviroment without taking up more space.

Please enable developer mode by clicking the button below to open the developer settings and check the \"Developer Mode\" box, then press the \"Retry\" button below"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3

